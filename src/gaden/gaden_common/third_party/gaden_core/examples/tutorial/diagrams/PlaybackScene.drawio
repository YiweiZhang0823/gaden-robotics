            <mxPoint x="-90" y="270" as="sourcePoint" />
            <mxPoint x="-20" y="270" as="targetPoint" />
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
